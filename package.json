{
  "name": "@json-render-plugins/recharts",
  "version": "0.0.2",
  "license": "MIT",
  "description": "Recharts component library for @json-render/core. JSON becomes beautiful Recharts charts with React rendering.",
  "keywords": [
    "json",
    "json-render",
    "ui",
    "react",
    "recharts",
    "chart",
    "visualization",
    "ai",
    "a2ui",
    "genui",
    "generative-ui",
    "llm",
    "renderer",
    "streaming",
    "components"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/json-render-plugins/recharts.git"
  },
  "homepage": "https://github.com/json-render-plugins/recharts#readme",
  "bugs": {
    "url": "https://github.com/json-render-plugins/recharts/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./catalog": {
      "types": "./dist/catalog.d.ts",
      "import": "./dist/catalog.mjs",
      "require": "./dist/catalog.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@json-render/core": "*",
    "@json-render/react": "*"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.0.0",
    "zod": "^4.0.0"
  }
}
